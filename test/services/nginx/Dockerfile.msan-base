ARG TOOLCHAIN_IMAGE=nginx_musl_toolchain
FROM ${TOOLCHAIN_IMAGE}

ARG ARCH=aarch64
ARG NGINX_VERSION
# Versions pinned to what Alpine 3.23.4 ships in the toolchain image.
ARG OPENSSL_VERSION=3.5.6
ARG ZLIB_VERSION=1.3.2
ARG PCRE2_VERSION=10.47

ENV MSAN_OPTIONS=halt_on_error=1:abort_on_error=1:fast_unwind_on_fatal=1

COPY openssl-msan-auxv.patch /openssl-msan-auxv.patch
COPY nginx-msan-crossbuild-probes.patch /nginx-msan-crossbuild-probes.patch

RUN set -eux; \
    case "$ARCH" in \
      arm64) ARCH=aarch64 ;; \
      amd64) ARCH=x86_64 ;; \
    esac; \
    sysroot="/sysroot/${ARCH}-none-linux-musl"; \
    triple="${ARCH}-none-linux-musl"; \
    addgroup -S nginx; \
    adduser -S -D -H -h /var/cache/nginx -s /sbin/nologin -G nginx nginx; \
    mkdir -p /var/cache/nginx /var/log/nginx /run; \
    mkdir -p "${sysroot}/usr/lib/resource_dir"; \
    ln -sfn "/usr/lib/llvm21/lib/clang/21/include" "${sysroot}/usr/lib/resource_dir/include"; \
    \
    msan_flags="-fsanitize=memory -fsanitize-memory-track-origins=2"; \
    clang_resource_dir=$(clang -print-resource-dir); \
    dep_cflags="--target=${triple} --sysroot=${sysroot} -fno-omit-frame-pointer -O1 -g ${msan_flags} -resource-dir ${sysroot}/usr/lib/resource_dir -isystem ${clang_resource_dir}/include"; \
    dep_ldflags="-fuse-ld=lld -rtlib=compiler-rt -unwindlib=libunwind ${msan_flags}"; \
    \
    # Download ALL sources before removing .so dev symlinks below.
    # wget links against the system libz.so.1 and libcrypto.so.3; those versioned
    # SONAME files are kept, but the -lz / -lssl linker dev symlinks are removed so
    # nginx links the MSan-instrumented static archives instead.
    cd /tmp; \
    wget -q "https://zlib.net/fossils/zlib-${ZLIB_VERSION}.tar.gz"; \
    wget -q "https://github.com/PhilipHazel/pcre2/releases/download/pcre2-${PCRE2_VERSION}/pcre2-${PCRE2_VERSION}.tar.bz2"; \
    wget -q "https://github.com/openssl/openssl/releases/download/openssl-${OPENSSL_VERSION}/openssl-${OPENSSL_VERSION}.tar.gz"; \
    wget -q "https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz"; \
    \
    # -----------------------------------------------------------------------
    # zlib: cmake instead of zlib's configure — cmake never runs compiled test
    # programs, avoiding the MSan personality(ADDR_NO_RANDOMIZE) seccomp issue.
    # -----------------------------------------------------------------------
    tar -xzf "zlib-${ZLIB_VERSION}.tar.gz"; \
    cmake -G Ninja \
      -S "/tmp/zlib-${ZLIB_VERSION}" \
      -B "/tmp/zlib-${ZLIB_VERSION}/build" \
      -DCMAKE_BUILD_TYPE=RelWithDebInfo \
      -DCMAKE_INSTALL_PREFIX="${sysroot}/usr" \
      -DCMAKE_INSTALL_LIBDIR=lib \
      -DCMAKE_C_COMPILER=clang \
      -DCMAKE_C_FLAGS="${dep_cflags}" \
      -DCMAKE_EXE_LINKER_FLAGS="${dep_ldflags}" \
      -DCMAKE_CROSSCOMPILING=TRUE \
      -DCMAKE_TRY_COMPILE_TARGET_TYPE=STATIC_LIBRARY \
      -DZLIB_BUILD_EXAMPLES=OFF; \
    # Build only the static target. zlib 1.3.x cmake always defines both a
    # static (zlibstatic) and shared (zlib) target regardless of BUILD_SHARED_LIBS;
    # the shared link fails with -fsanitize=memory because clang tries to embed
    # the static MSan runtime into the .so, which is not supported.
    cmake --build "/tmp/zlib-${ZLIB_VERSION}/build" --target zlibstatic -j"$(nproc)"; \
    # zlibstatic has OUTPUT_NAME=z so the archive is libz.a. Install lib + headers.
    install -m 644 "/tmp/zlib-${ZLIB_VERSION}/build/libz.a" "${sysroot}/usr/lib/"; \
    install -m 644 "/tmp/zlib-${ZLIB_VERSION}/zlib.h" \
                   "/tmp/zlib-${ZLIB_VERSION}/build/zconf.h" \
                   "${sysroot}/usr/include/"; \
    rm -rf "/tmp/zlib-${ZLIB_VERSION}" "/tmp/zlib-${ZLIB_VERSION}.tar.gz"; \
    \
    # -----------------------------------------------------------------------
    # pcre2: autoconf with --host enables cross-compile mode, so probes are
    # compiled but not executed. JIT disabled (MSan cannot instrument JIT code).
    # -----------------------------------------------------------------------
    cd /tmp; \
    tar -xjf "pcre2-${PCRE2_VERSION}.tar.bz2"; \
    cd "/tmp/pcre2-${PCRE2_VERSION}"; \
    CC=clang CFLAGS="${dep_cflags}" LDFLAGS="${dep_ldflags}" \
      ./configure \
        --host="${triple}" \
        --prefix="${sysroot}/usr" \
        --libdir="${sysroot}/usr/lib" \
        --enable-static \
        --disable-shared \
        --disable-jit \
        --disable-pcre2-16 \
        --disable-pcre2-32 \
        --disable-pcre2grep-libz \
        --disable-pcre2grep-libbz2 \
        --disable-pcre2test-libedit; \
    make -j"$(nproc)"; \
    make install; \
    rm -f "${sysroot}/usr/lib/libpcre2-8.so" "${sysroot}/usr/lib/libpcre2-posix.so"; \
    rm -rf "/tmp/pcre2-${PCRE2_VERSION}" "/tmp/pcre2-${PCRE2_VERSION}.tar.bz2"; \
    \
    # -----------------------------------------------------------------------
    # OpenSSL: perl-based Configure does not exec instrumented programs.
    # no-asm required: MSan cannot instrument hand-written assembly.
    # auxv.patch removes the glibc-only guard around sys/auxv.h for musl.
    # -----------------------------------------------------------------------
    cd /tmp; \
    tar -xzf "openssl-${OPENSSL_VERSION}.tar.gz"; \
    case "$ARCH" in \
      x86_64)  ossl_target="linux-x86_64-clang"; ossl_optflags="enable-ec_nistp_64_gcc_128" ;; \
      aarch64) ossl_target="linux-aarch64"; ossl_optflags="" ;; \
      *)       ossl_target="linux-${ARCH}"; ossl_optflags="" ;; \
    esac; \
    cd "/tmp/openssl-${OPENSSL_VERSION}"; \
    patch -p1 < /openssl-msan-auxv.patch; \
    CC=clang ./Configure "$ossl_target" \
      --prefix="${sysroot}/usr" \
      --libdir=lib \
      no-shared no-threads no-tests no-asm \
      no-zlib no-async no-comp no-idea no-mdc2 no-rc5 no-ec2m no-ssl3 no-seed \
      no-weak-ssl-ciphers \
      ${ossl_optflags} \
      --target=${triple} --sysroot=${sysroot} \
      -fno-omit-frame-pointer -O1 -g ${msan_flags} \
      -isystem ${clang_resource_dir}/include \
      -fuse-ld=lld -rtlib=compiler-rt -unwindlib=libunwind \
      -resource-dir ${sysroot}/usr/lib/resource_dir; \
    make -j"$(nproc)"; \
    make install_sw LIBDIR=lib; \
    rm -f "${sysroot}/usr/lib/libssl.so" "${sysroot}/usr/lib/libcrypto.so"; \
    rm -rf "/tmp/openssl-${OPENSSL_VERSION}" "/tmp/openssl-${OPENSSL_VERSION}.tar.gz" \
           "/openssl-msan-auxv.patch"; \
    \
    # -----------------------------------------------------------------------
    # nginx: nginx-msan-crossbuild-probes.patch adds NGX_MUSL_CROSSBUILD guards to
    # auto/types/sizeof, auto/feature, and auto/endianness so that probe programs are
    # never executed. This avoids the personality(ADDR_NO_RANDOMIZE) re-exec that
    # MSan triggers and that Docker's default seccomp profile blocks.
    # NGX_MUSL_CROSSBUILD_ARCH supplies the hardcoded size/endian presets.
    # --crossbuild sets the OS string in nginx's config output (separate concern).
    # -----------------------------------------------------------------------
    cd /tmp; \
    tar -xzf "nginx-${NGINX_VERSION}.tar.gz"; \
    cc_opt="--target=${triple} --sysroot=${sysroot} -fno-omit-frame-pointer -O1 -g ${msan_flags} -DNGX_COMPAT=1 -Wno-error=sign-compare"; \
    ld_opt="--target=${triple} --sysroot=${sysroot} -fuse-ld=lld -rtlib=compiler-rt -unwindlib=libunwind -resource-dir ${sysroot}/usr/lib/resource_dir ${msan_flags} -Wl,-rpath,/usr/msan/lib -Wl,-rpath,/usr/lib"; \
    cd "/tmp/nginx-${NGINX_VERSION}"; \
    patch -p1 < /nginx-msan-crossbuild-probes.patch; \
    NGX_MUSL_CROSSBUILD=YES NGX_MUSL_CROSSBUILD_ARCH="${ARCH}" ./configure \
      --prefix=/etc/nginx \
      --sbin-path=/usr/sbin/nginx \
      --modules-path=/usr/lib/nginx/modules \
      --conf-path=/etc/nginx/nginx.conf \
      --error-log-path=/var/log/nginx/error.log \
      --http-log-path=/var/log/nginx/access.log \
      --pid-path=/run/nginx.pid \
      --lock-path=/var/run/nginx.lock \
      --http-client-body-temp-path=/var/cache/nginx/client_temp \
      --http-proxy-temp-path=/var/cache/nginx/proxy_temp \
      --http-fastcgi-temp-path=/var/cache/nginx/fastcgi_temp \
      --http-uwsgi-temp-path=/var/cache/nginx/uwsgi_temp \
      --http-scgi-temp-path=/var/cache/nginx/scgi_temp \
      --user=nginx \
      --group=nginx \
      --with-compat \
      --with-file-aio \
      --with-threads \
      --with-http_auth_request_module \
      --with-http_ssl_module \
      --with-http_v2_module \
      --with-http_v3_module \
      --with-http_stub_status_module \
      --with-http_realip_module \
      --with-http_gzip_static_module \
      --with-http_sub_module \
      --crossbuild="Linux:5.10.0:${ARCH}" \
      --with-cc=clang \
      --with-cc-opt="${cc_opt}" \
      --with-ld-opt="${ld_opt}"; \
    make -j"$(nproc)"; \
    make install; \
    rm -rf "/tmp/nginx-${NGINX_VERSION}" "/tmp/nginx-${NGINX_VERSION}.tar.gz" \
           "/nginx-msan-crossbuild-probes.patch"

ENV PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
