{
  "version": "2.1",
  "metadata": {
    "rules_version": "1.2.6"
  },
  "rules": [
    {
      "id": "match_keys",
      "name": "Match keys",
      "tags": {
        "type": "security_scanner",
        "category": "attack_attempt"
      },
      "conditions": [
        {
          "parameters": {
            "inputs": [
              {
                "address": "server.request.query"
              }
            ],
            "regex": "^(?:%(?:a)?)?matched key(?:%(?:a)?)?$"
          },
          "operator": "match_regex"
        }
      ],
      "transformers": [
        "keys_only"
      ]
    },
    {
      "id": "match_values",
      "name": "Match values",
      "tags": {
        "type": "security_scanner",
        "category": "attack_attempt"
      },
      "conditions": [
        {
          "parameters": {
            "inputs": [
              {
                "address": "server.request.query"
              }
            ],
            "regex": "^(?:%(?:a)?)?matched value(?:%(?:a)?)?$$"
          },
          "operator": "match_regex"
        }
      ],
      "transformers": [
        "values_only"
      ]
    }
  ]
}
