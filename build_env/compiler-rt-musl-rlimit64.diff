+#if SANITIZER_MUSL
+// musl has no separate 64-bit resource/statvfs variants; the *64 names alias
+// the base structs. MSan's getrlimit64/prlimit64 interceptors still reference
+// struct_rlimit64_sz, so define the sizes here to match the base structs and
+// avoid an undefined reference when linking the MSan runtime against musl.
+unsigned struct_rlimit64_sz = sizeof(struct rlimit);
+unsigned struct_statvfs64_sz = sizeof(struct statvfs);
+#endif // SANITIZER_MUSL
