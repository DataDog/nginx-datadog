-#define SI_STAT_LINUX (SI_LINUX && __GLIBC_PREREQ(2, 33))
+// On glibc >= 2.33 the stat family (stat/fstat/lstat/...) are real exported
+// symbols rather than __xstat/__fxstat wrappers, and SI_STAT_LINUX gates the
+// interceptors for them. musl also exports plain stat/fstat/lstat directly and
+// never uses the __xstat wrappers, so enable the stat interceptors there too;
+// otherwise the struct stat filled by fstat() is never unpoisoned (MSan) and
+// triggers a false use-of-uninitialized-value.
+#define SI_STAT_LINUX (SI_LINUX && (__GLIBC_PREREQ(2, 33) || SANITIZER_MUSL))
 #define SANITIZER_INTERCEPT_STAT                                    \
   (SI_FREEBSD || SI_MAC || SI_ANDROID || SI_NETBSD || SI_SOLARIS || \
    SI_STAT_LINUX || !SI_NOT_AIX)
