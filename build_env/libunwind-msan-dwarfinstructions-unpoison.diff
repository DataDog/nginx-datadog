 #include <stdio.h>
 #include <stdlib.h>
 
+// MSan's poison_in_dtor=1 (the default) poisons object fields when a destructor
+// runs. When C++ exception unwinding steps through a frame whose stack contains
+// a destroyed object, DwarfInstructions reads saved register values from stack
+// slots that overlap those poisoned bytes, triggering a false
+// use-of-uninitialized-value. Unpoison before each stack read: the register
+// value was written there before the object was constructed; reading it for
+// stack-unwinding is valid.
+#if defined(__has_feature) && __has_feature(memory_sanitizer)
+#include <sanitizer/msan_interface.h>
+#endif
+
